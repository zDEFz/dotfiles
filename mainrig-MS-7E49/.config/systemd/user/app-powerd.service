[Unit]
Description=app-powerd battery-saving daemon
Documentation=https://github.com/johnlepikhin/app-powerd

[Service]
Type=simple
# Using %h expands to your home directory, followed by the correct path
ExecStart=%h/.cargo/bin/app-powerd run
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
