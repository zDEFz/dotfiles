gpu_pci_address() 
{
    lspci -nn | grep -i vga | while read -r line; do
        PCI_ADDRESS=$(echo "$line" | awk '{print $1}')
        VENDOR_ID=$(echo "$line" | grep -oP '\[([0-9a-fA-F]{4}):' | cut -d: -f1 | tr -d '[]')
        DEVICE_ID=$(echo "$line" | grep -oP ':[0-9a-fA-F]{4}\]' | cut -d: -f2 | tr -d ']')
        
        # Extract just the GPU model name between the brackets after AMD/ATI
        GPU_NAME=$(echo "$line" | grep -oP '\[AMD/ATI\] [^[]*\[[^]]*\]' | sed 's/\[AMD\/ATI\] //')
        
        # Get the driver the GPU is currently using
        GPU_DRIVER=$(lspci -k -s "$PCI_ADDRESS" | grep "Kernel driver in use" | awk '{print $NF}')
        if [ -z "$GPU_DRIVER" ]; then
            GPU_DRIVER="No driver bound"
        fi
        
        # Get available modules for the GPU
        GPU_MODULES=$(lspci -k -s "$PCI_ADDRESS" | grep "Kernel modules" | sed 's/Kernel modules: //')
        if [ -z "$GPU_MODULES" ]; then
            GPU_MODULES="None available"
        fi
        
        # Find the audio device on the same bus
        GPU_BUS=$(echo "$PCI_ADDRESS" | cut -d: -f1)
        AUDIO_DEVICE=$(lspci -nn | grep "$GPU_BUS" | grep -i "audio\|hdmi" | head -1)
        
        if [ -n "$AUDIO_DEVICE" ]; then
            AUDIO_PCI=$(echo "$AUDIO_DEVICE" | awk '{print $1}')
            AUDIO_VENDOR=$(echo "$AUDIO_DEVICE" | grep -oP '\[([0-9a-fA-F]{4}):' | cut -d: -f1 | tr -d '[]')
            AUDIO_ID=$(echo "$AUDIO_DEVICE" | grep -oP ':[0-9a-fA-F]{4}\]' | cut -d: -f2 | tr -d ']')
            
            # Get the driver the audio device is using
            AUDIO_DRIVER=$(lspci -k -s "$AUDIO_PCI" | grep "Kernel driver in use" | awk '{print $NF}')
            if [ -z "$AUDIO_DRIVER" ]; then
                AUDIO_DRIVER="No driver bound"
            fi
            
            # Get available modules for the audio device
            AUDIO_MODULES=$(lspci -k -s "$AUDIO_PCI" | grep "Kernel modules" | sed 's/Kernel modules: //')
            if [ -z "$AUDIO_MODULES" ]; then
                AUDIO_MODULES="None available"
            fi
        else
            AUDIO_PCI="Not found"
            AUDIO_VENDOR="N/A"
            AUDIO_ID="N/A"
            AUDIO_DRIVER="N/A"
            AUDIO_MODULES="N/A"
        fi
        
        echo "PCI Address: $PCI_ADDRESS"
        echo "Vendor ID: $VENDOR_ID" 
        echo "Device ID: $DEVICE_ID"
        echo "GPU Name: $GPU_NAME"
        echo "GPU Driver: $GPU_DRIVER"
        echo "GPU Available Modules: $GPU_MODULES"
        echo "Audio PCI: $AUDIO_PCI"
        echo "Audio Vendor ID: $AUDIO_VENDOR"
        echo "Audio Device ID: $AUDIO_ID"
        echo "Audio Driver: $AUDIO_DRIVER"
        echo "Audio Available Modules: $AUDIO_MODULES"
        echo "--------------------------------------"
    done
}



