# Wayland/X11 utilities
alias get_cursor_pos='slurp -b 00000000'

# Dual display capture card setup with rotation and framerate adjustment
capturecard () { 
    ffplay -f v4l2 -video_size 1920x1080 -framerate 60 --untimed -i /dev/video0 -vf "transpose=1,setpts=PTS/2" > /dev/null 2>&1 & 
    ffplay -f v4l2 -video_size 1920x1080 -framerate 60 --untimed -i /dev/video1 -vf "setpts=PTS/2" > /dev/null 2>&1 &
}

# MPV player variants
alias mpvloop='mpv --loop'

# mpvl
for i in $(seq 1 99); do
    eval "mpvl$i() {
        id=\"mpvfloat$i\"
        if pgrep -f -- \"--wayland-app-id=\$id\" > /dev/null; then
            echo \"mpvl$i with app_id \$id is already running. Skipping...\"
            return 0
        fi

        args=()
        pause_flag=1

        for arg in \"\$@\"; do
            if [[ \"\$arg\" == \"--nopause\" ]]; then
                pause_flag=0
            else
                args+=(\"\$arg\")
            fi
        done

        cmd=(mpv --force-window=yes)
        (( pause_flag )) && cmd+=(--pause)
        cmd+=(--keep-open \\
              --directory-mode=recursive \\
              --directory-filter-types=video,audio \\
              --autofit-larger=192x108 --geometry=192x108 \\
              --config-dir=/home/blu/.config/mpv/profiles/openmusic \\
              --x11-name=\"\$id\" --wayland-app-id=\"\$id\")
        cmd+=(\"\${args[@]}\")
        \"\${cmd[@]}\" > /dev/null 2>&1 &
    }"
done





