# i3 config main file
set { 
    $a app_id
    $alt Mod1
    $as assign
    $bc bindcode
    $bm bindsym
    $bp0 border pixel 0
    $c class
    $ctrl Mod2
    $e exec
    $ea exec_always
    $ensi exec --no-startup-id
    $f focus
    $fd focus down
    $fe floating enable
    $fl focus left
    $fr focus right
    $fs fullscreen enable
    $fst fullscreen toggle
    $fu focus up
    $fw for_window
    $i instance
    $map move absolute position
    $mctw move container to workspace
    $md move down
    $meta Mod4
    $ml move left
    $mp move position
    $mpc move position center
    $mr move right
    $mto move to output
    $mtod move to output down
    $mtol move to output left
    $mtor move to output right
    $mtou move to output up
    $mtp move to position
    $mts move to scratchpad
    $mtw move to workspace
    $mu move up
    $n name
    $rs resize set
    $t title
    $ubin /usr/bin
    $ws workspace
}

# Mouse
# Use Mouse+$meta to drag floating windows to their wanted position
floating_modifier $meta 
focus_follows_mouse no
mouse_warping none

# No urgency marks focus_on_window_activation smart|urgent|focus|none
focus_on_window_activation none

# PS4 controller disable touchpad / mouse
input {
    '1356:2508:Sony_Interactive_Entertainment_Wireless_Controller_Touchpad' events disabled
    type:keyboard xkb_numlock enabled
    '0:0:wlr_virtual_keyboard_v1' events disabled
    '0:0:antimicrox_Mouse_Emulation' events disabled
    '0:0:antimicrox_Abs_Mouse_Emulation' events disabled
}

# Displays
set { 
    $LL     'Iiyama North America PL2590HS 1219241201677'
    $L      'BNQ ZOWIE XL LCD EBX7M01214SL0'
    $M      'BNQ ZOWIE XL LCD EBF2R02370SL0'
    $MON_KB 'Iiyama North America PL2590HS 1219241201302'
    $R      'BNQ ZOWIE XL LCD EBMCM01300SL0'
    $RR     'Iiyama North America PL2590HS 1219241201699'
    $TAIKO  'Iiyama North America PL2590HS 1219241201616'
}

# Display modes
output {
    $LL     mode 1920x1080@240Hz
    $L      mode 1920x1080@240Hz
    $M      mode 1920x1080@360Hz
    $MON_KB mode 1920x1080@240Hz
    $R      mode 1920x1080@240Hz
    $RR     mode 1920x1080@240Hz
    $TAIKO  mode 1920x1080@240Hz
}

# Display positions
output {
    $LL     position 0 380 
    $L      position 1080 350
    $M      position 2160 464
    $MON_KB position 2160 1544
    $R      position 4080 354
    $RR     position 5160 384
    $TAIKO  position 6240 384
}

# Display backgrounds
output {
    *       background /home/blu/.config/sway/wallpaper/9x16-Portrait.png fill
    $M      background /home/blu/.config/sway/wallpaper/16x9-Landscape.png fill
    $MON_KB background /home/blu/.config/sway/wallpaper/16x9-Landscape.png fill
    $TAIKO  background /home/blu/.config/sway/wallpaper/16x9-Landscape.png fill
}

# Display transforms
output { 
    $L      transform 270
    $LL     transform 90
    $MON_KB transform 180
    $R      transform 270
    $RR     transform 270
}

include /home/blu/.config/sway/conf.d/workspaces/workspace-definitions.conf

# Theming

font pango: Noto Mono Nerd Font Complete 11, Hack 11, IPAPGothic 11, Noto Sans Mono CJK JP 11, FontAwesome 11, Hack Nerd Font Mono 11

# Color shemes for windows
set { 
    $bgcolor    #2d6876
    $in-bgcolor #363636
    $text       #ffffff
    $u-bgcolor  #ff0000
    $indicator  #a8a3c1
    $in-text    #969696
}

#                       border          background      text            indicator (a line which shows where the next window will be placed)
client.focused          $bgcolor        $bgcolor        $text           $indicator
client.unfocused        $in-bgcolor     $in-bgcolor     $in-text        $in-bgcolor
client.focused_inactive $in-bgcolor     $in-bgcolor     $in-text        $in-bgcolor
# client.urgent           $bgcolor        $bgcolor        $in-text        $bgcolor

set {
    $black        #282828
    $darkred      #cc241d
    $darkgreen    #98971a
    $darkyellow   #d79921
    $darkblue     #458588
    $darkmagenta  #b16286
    $darkcyan     #689d6a
    $lightgray    #a89984
    $darkgray     #928374
    $red          #fb4934
    $green        #b8bb26
    $yellow       #fabd2f
    $blue         #83a598
    $magenta      #d3869b
    $cyan         #8ec07c
    $white        #ebdbb2
}
output $TAIKO disable


## Workaround for xwayland pos 0 0 applications

output { 
    $MON_KB position 0 0

    $LL     position 1920 350 
    $L      position 3000 350
    $M      position 4080 464
    
    $R      position 6000 354
    $RR     position 7080 384
    $TAIKO  position 8160 384
}
focus_follows_mouse yes
mouse_warping output

## Workaround END




include ~/.config/sway/conf.d/*