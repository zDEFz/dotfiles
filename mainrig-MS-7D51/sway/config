# i3 config main file
# shellcheck disable=SC2148

# default_border none
# default_floating_border none

# titlebar_padding 2
# titlebar_border_thickness 0

set $meta Mod4
set $alt Mod1
set $ctrl Mod2

set $a app_id
set $as assign
set $bc bindcode
set $bm bindsym
set $bp0 border pixel 0
set $c class
set $e exec
set $ea exec_always
set $ensi exec --no-startup-id
set $f focus
set $fd focus down
set $fe floating enable
set $fl focus left
set $fr focus right
set $fs fullscreen enable
set $fst fullscreen toggle
set $fu focus up
set $fw for_window
set $i instance
set $map move absolute position
set $mctw move container to workspace
set $md move down
set $ml move left
set $mp move position
set $mpc move position center
set $mr move right
set $mto move to output
set $mtod move to output down
set $mtol move to output left
set $mtor move to output right
set $mtou move to output up
set $mtp move to position
set $mts move to scratchpad
set $mtw move to workspace
set $mu move up
set $n name
set $rs resize set
set $t title
set $ubin /usr/bin
set $ws workspace

# Use Mouse+$meta to drag floating windows to their wanted position
floating_modifier $meta

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
# tiling_drag modifier titlebar

# Mouse
mouse_warping none
focus_follows_mouse no

# PS4 controller disable touchpad / mouse
input '1356:2508:Sony_Interactive_Entertainment_Wireless_Controller_Touchpad' events disabled

# Keyboard
input type:keyboard xkb_numlock enabled

# disable power saving (for example if using xscreensaver)
# $ensi xset -dpms
# $ensi xset -dpms s off

### WORKSPACES
# set $R DisplayPort-0
#set $L DisplayPort-1

set $L 'BNQ ZOWIE XL LCD EBX7M01214SL0'
set $LL "LG Electronics 24GM79G 0x0008042C"
set $R 'BNQ ZOWIE XL LCD EBF2R02905SL0'
set $RR 'BNQ ZOWIE XL LCD EBMCM01300SL0'


#output * adaptive_sync on

# Set up the left display
# Feels too dark
        #output $L color_profile icc '/usr/share/color/icc/colord/XL2546K-L-120-cdm-D6500.icc' mode 1920x1080@144Hz transform 270 position 0 0
        #output $R color_profile icc '/usr/share/color/icc/colord/XL2546K-R-120-cdm-D6500.icc' mode 1920x1080@144Hz position 1080 340
    # without profile

     #background /home/blu/.config/sway/wallpaper/DP-2/1.png fill
     #background /home/blu/.config/sway/wallpaper/DP-1/2.png fill

output $LL {
    background /home/blu/.config/sway/wallpaper/LL_SCREEN/1080x1920.png fill
    color_profile srgb 
    mode 1920x1080@144Hz
    position 0 0
    render_bit_depth 8
    resolution 1920x1080
    scale_filter smart
    subpixel rgb
    transform 270
}

output $L {
    background /home/blu/.config/sway/wallpaper/L_SCREEN/1080x1920.png fill
    color_profile srgb 
    mode 1920x1080@240Hz
    position 1080 0
    render_bit_depth 8
    resolution 1920x1080
    scale_filter smart
    subpixel rgb
    transform 270
}

output $R {
    background /home/blu/.config/sway/wallpaper/R_SCREEN/1920x1080.png fill
    color_profile srgb 
    mode 1920x1080@360Hz
    position 2160 342
    render_bit_depth 8
    resolution 1920x1080
    scale_filter smart
    subpixel rgb
}

output $RR {
    background /home/blu/.config/sway/wallpaper/RR_SCREEN/1080x1920.png fill
    color_profile srgb 
    mode 1920x1080@240Hz
    position 4080 14
    render_bit_depth 8
    resolution 1920x1080
    scale_filter smart
    subpixel rgb
    transform 270
}

include ~/.config/sway/workspace-definitions.conf

# Theming

font pango: Noto Mono Nerd Font Complete 11, Hack 11, IPAPGothic 11, Noto Sans Mono CJK JP 11, FontAwesome 11, Hack Nerd Font Mono 11

# Color shemes for windows
set $bgcolor    #2d6876
set $in-bgcolor #363636
set $text       #ffffff
set $u-bgcolor  #ff0000
set $indicator  #a8a3c1
set $in-text    #969696
#                       border          background      text            indicator (a line which shows where the next window will be placed)
client.focused          $bgcolor        $bgcolor        $text           $indicator
client.unfocused        $in-bgcolor     $in-bgcolor     $in-text        $in-bgcolor
client.focused_inactive $in-bgcolor     $in-bgcolor     $in-text        $in-bgcolor
client.urgent           $u-bgcolor      $u-bgcolor      $text           $u-bgcolor

set $black        #282828
set $darkred      #cc241d
set $darkgreen    #98971a
set $darkyellow   #d79921
set $darkblue     #458588
set $darkmagenta  #b16286
set $darkcyan     #689d6a
set $lightgray    #a89984
set $darkgray     #928374
set $red          #fb4934
set $green        #b8bb26
set $yellow       #fabd2f
set $blue         #83a598
set $magenta      #d3869b
set $cyan         #8ec07c
set $white        #ebdbb2

include ~/.config/sway/conf.d/*

