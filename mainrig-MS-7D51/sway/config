# i3 config main file
set { 
    $a app_id
    $alt Mod1
    $as assign
    $bc bindcode
    $bm bindsym
    $bp0 border pixel 0
    $c class
    $ctrl Mod2
    $e exec
    $ea exec_always
    $ensi exec --no-startup-id
    $f focus
    $fd focus down
    $fe floating enable
    $fl focus left
    $fr focus right
    $fs fullscreen enable
    $fst fullscreen toggle
    $fu focus up
    $fw for_window
    $i instance
    $map move absolute position
    $mctw move container to workspace
    $md move down
    $meta Mod4
    $ml move left
    $mp move position
    $mpc move position center
    $mr move right
    $mto move to output
    $mtod move to output down
    $mtol move to output left
    $mtor move to output right
    $mtou move to output up
    $mtp move to position
    $mts move to scratchpad
    $mtw move to workspace
    $mu move up
    $n name
    $rs resize set
    $t title
    $ubin /usr/bin
    $ws workspace
}

# Mouse
# Use Mouse+$meta to drag floating windows to their wanted position
floating_modifier $meta 
focus_follows_mouse no
mouse_warping none

# Urgency Marks
# urgent deny

# PS4 controller disable touchpad / mouse
input {
    '1356:2508:Sony_Interactive_Entertainment_Wireless_Controller_Touchpad' events disabled
    type:keyboard xkb_numlock enabled
    '0:0:wlr_virtual_keyboard_v1' events disabled
    '0:0:antimicrox_Mouse_Emulation' events disabled
    '0:0:antimicrox_Abs_Mouse_Emulation' events disabled
    "1189:32772:BenQ_ZOWIE_BenQ_ZOWIE_Gaming_Mouse" xkb_disabled yes
}

# Displays
set { 
    $L 'BNQ ZOWIE XL LCD EBX7M01214SL0'
    $LL "LG Electronics 24GM79G 0x0008042C"
    $M 'BNQ ZOWIE XL LCD EBF2R02370SL0'
    $MON_KB 'Iiyama North America PL2590HS 1219241201302'
    $R 'BNQ ZOWIE XL LCD EBMCM01300SL0'
    $TAIKO ''
}

output $LL {
    background /home/blu/.config/sway/wallpaper/9x16-Portrait.png fill
    mode 1920x1080@144Hz
    position 0 0
    render_bit_depth 8
    subpixel rgb
    # transform 270
}

output $L {
    background /home/blu/.config/sway/wallpaper/9x16-Portrait.png fill
    mode 1920x1080@240Hz
    position 1080 0
    render_bit_depth 8
    subpixel rgb
    transform 270
}

output $M {
    background /home/blu/.config/sway/wallpaper/16x9-Landscape.png fill
    mode 1920x1080@360Hz
    position 2160 354
    render_bit_depth 8
    subpixel rgb
}

output $MON_KB {
    background /home/blu/.config/sway/wallpaper/16x9-Landscape-Perf.png fill
    mode 1920x1080@240Hz
    position 2160 1434
    render_bit_depth 8
    subpixel rgb
    transform 180
}

output $R {
    background /home/blu/.config/sway/wallpaper/9x16-Portrait.png fill
    mode 1920x1080@240Hz
    position 4080 8
    render_bit_depth 8
    subpixel rgb
    transform 270
}

